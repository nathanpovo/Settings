[
  {
    "version" : 2
  },
  {
    "action" : {
      "script" : "git diff ${sha}^ ${sha} -- \"${file}\" | git apply --3way",
      "showOutput" : false,
      "type" : "sh",
      "waitForExit" : true
    },
    "name" : "Apply Diff from Commit",
    "target" : "file"
  },
  {
    "action" : {
      "script" : "git diff ${sha} ${sha}^ -- \"${file}\" | git apply --3way",
      "showOutput" : false,
      "type" : "sh",
      "waitForExit" : true
    },
    "name" : "Apply Diff from Commit - Inverse",
    "target" : "file"
  },
  {
    "name" : "Apply patch (three-way merge)",
    "target" : "repository",
    "ui" : {
      "buttons" : [
        {
          "action" : {
            "args" : "am -3 $1{path} $2{value} $3{value}",
            "path" : "${git}",
            "showOutput" : true,
            "type" : "process",
            "waitForExit" : true
          },
          "title" : "OK"
        },
        {
          "action" : {
            "type" : "cancel"
          },
          "title" : "Cancel"
        }
      ],
      "controls" : [
        {
          "defaultDirectory" : "",
          "dialogType" : "openFile",
          "filename" : "",
          "textBoxType" : "filepath",
          "title" : "Path Text Box",
          "type" : "textBox"
        },
        {
          "checkedValue" : "--ignore-whitespace",
          "defaultValue" : true,
          "title" : "Ignore whitespace",
          "type" : "checkBox",
          "uncheckedValue" : ""
        },
        {
          "checkedValue" : "--ignore-space-change",
          "defaultValue" : true,
          "title" : "Ignore space change",
          "type" : "checkBox",
          "uncheckedValue" : ""
        }
      ],
      "description" : "Are you sure you want to execute custom command?",
      "title" : "Apply patch (three-way merge)"
    }
  },
  {
    "action" : {
      "args" : "checkout -m ${sha:abbr} -- \"${file}\"",
      "path" : "$git",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Checkout file",
    "target" : "file"
  },
  {
    "action" : {
      "args" : "-c 'echo ${sha:abbr} | clip'",
      "path" : "$sh",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : false
    },
    "name" : "Copy Commit Abbreviated SHA",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "merge ${sha:abbr}",
      "path" : "$git",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : false
    },
    "name" : "Merge Commit Into Current Branch",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "-d \"${file}\"",
      "path" : "%LOCALAPPDATA%\\Microsoft\\WindowsApps\\wt.exe",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : false
    },
    "name" : "Open in Terminal",
    "target" : "file"
  },
  {
    "action" : {
      "args" : "\"${file}\"",
      "path" : "%LOCALAPPDATA%\\Programs\\Microsoft VS Code\\Code.exe",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : false
    },
    "name" : "Open in VS Code",
    "target" : "file"
  },
  {
    "action" : {
      "args" : "\"${file}\" --disable-extensions --new-window",
      "path" : "%LOCALAPPDATA%\\Programs\\Microsoft VS Code\\Code.exe",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : false
    },
    "name" : "Open in VS Code - lightweight",
    "target" : "file"
  },
  {
    "action" : {
      "args" : "${repo:path} --disable-extensions",
      "path" : "%LOCALAPPDATA%\\Programs\\Microsoft VS Code\\Code.exe",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : false
    },
    "name" : "Open in VS Code - lightweight",
    "target" : "repository"
  },
  {
    "action" : {
      "args" : "rebase --rebase-merges ${sha}",
      "path" : "$git",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Rebase (Rebase Merges) to Here...",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "rebase --update-refs ${sha}",
      "path" : "$git",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Rebase (Updated refs) to Here...",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "rebase --interactive --autostash ${sha}",
      "path" : "$git",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Rebase Interactively (Auto Stash) to Here...",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "rebase --interactive --rebase-merges ${sha}",
      "path" : "$git",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Rebase Interactively (Rebase Merges) to Here...",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "rebase --interactive --update-refs ${sha:abbr}",
      "path" : "$git",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Rebase Interactively (Updated refs) to Here...",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "restore -s ${sha} .",
      "path" : "${git}",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Restore files to commit",
    "target" : "revision"
  },
  {
    "action" : {
      "args" : "restore -s ${sha} -- \"${file}\"",
      "path" : "${git}",
      "showOutput" : false,
      "type" : "process",
      "waitForExit" : true
    },
    "name" : "Restore files to commit",
    "target" : "file"
  },
  {
    "action" : {
      "script" : "git --no-pager log --all --first-parent --author-date-order --format=%S -- '${file}'",
      "showOutput" : true,
      "type" : "sh",
      "waitForExit" : true
    },
    "name" : "Show branches that modified file",
    "target" : "file"
  }
]